/* USER CODE BEGIN 4 */
void HAL_GPIO_EXTI_Callback(uint16_t GPIO_pin){
	if(GPIO_pin == BS_Pin){
		ready = 1;
		timer = 0;
		go = 0;
		finish = 0;
		contador1 = 0;
		contador2 = 0;
		// Apagamos leds
		HAL_GPIO_WritePin(L11_GPIO_Port, L11_Pin, 0);
		HAL_GPIO_WritePin(L12_GPIO_Port, L12_Pin, 0);
		HAL_GPIO_WritePin(L13_GPIO_Port, L13_Pin, 0);
		HAL_GPIO_WritePin(L14_GPIO_Port, L14_Pin, 0);
		HAL_GPIO_WritePin(L21_GPIO_Port, L21_Pin, 0);
		HAL_GPIO_WritePin(L22_GPIO_Port, L22_Pin, 0);
		HAL_GPIO_WritePin(L23_GPIO_Port, L23_Pin, 0);
		HAL_GPIO_WritePin(L24_GPIO_Port, L24_Pin, 0);
	}
	else if(GPIO_pin == B1C5_Pin){
		if(go == 1 && finish == 0){
			contador1++;
		}
		if(go == 1 && contador1 < 4 && finish == 0){
			if(contador1 == 1){
				// Encender 1000
				HAL_GPIO_WritePin(L11_GPIO_Port, L11_Pin, 1);
				HAL_GPIO_WritePin(L12_GPIO_Port, L12_Pin, 0);
				HAL_GPIO_WritePin(L13_GPIO_Port, L13_Pin, 0);
				HAL_GPIO_WritePin(L14_GPIO_Port, L14_Pin, 0);
			}else if(contador1 == 2){
				// Encender 0100
				HAL_GPIO_WritePin(L11_GPIO_Port, L11_Pin, 0);
				HAL_GPIO_WritePin(L12_GPIO_Port, L12_Pin, 1);
				HAL_GPIO_WritePin(L13_GPIO_Port, L13_Pin, 0);
				HAL_GPIO_WritePin(L14_GPIO_Port, L14_Pin, 0);
			}else if(contador1 == 3){
				// Encender 0010
				HAL_GPIO_WritePin(L11_GPIO_Port, L11_Pin, 0);
				HAL_GPIO_WritePin(L12_GPIO_Port, L12_Pin, 0);
				HAL_GPIO_WritePin(L13_GPIO_Port, L13_Pin, 1);
				HAL_GPIO_WritePin(L14_GPIO_Port, L14_Pin, 0);
			}
		}else if (contador1 == 4){
			// Se termina juego
			finish = 1;
			// Encender todas las leds jugador 1
			HAL_GPIO_WritePin(L11_GPIO_Port, L11_Pin, 1);
			HAL_GPIO_WritePin(L12_GPIO_Port, L12_Pin, 1);
			HAL_GPIO_WritePin(L13_GPIO_Port, L13_Pin, 1);
			HAL_GPIO_WritePin(L14_GPIO_Port, L14_Pin, 1);
			// Apagamos todas las leds jugador 2
			HAL_GPIO_WritePin(L21_GPIO_Port, L21_Pin, 0);
			HAL_GPIO_WritePin(L22_GPIO_Port, L22_Pin, 0);
			HAL_GPIO_WritePin(L23_GPIO_Port, L23_Pin, 0);
			HAL_GPIO_WritePin(L24_GPIO_Port, L24_Pin, 0);
			// Mostramos 1 en display
			HAL_GPIO_WritePin(D0_GPIO_Port, D0_Pin, 0);
			HAL_GPIO_WritePin(D1_GPIO_Port, D1_Pin, 0);
			HAL_GPIO_WritePin(D2_GPIO_Port, D2_Pin, 0);
			HAL_GPIO_WritePin(D3_GPIO_Port, D3_Pin, 1);
			HAL_GPIO_WritePin(D4_GPIO_Port, D4_Pin, 0);
			HAL_GPIO_WritePin(D5_GPIO_Port, D5_Pin, 0);
			HAL_GPIO_WritePin(D6_GPIO_Port, D6_Pin, 1);
		}
	}
	else if(GPIO_pin == B2_Pin){
			if(go == 1 && finish == 0){
				contador2++;
			}
			if(go == 1 && contador2 < 4 && finish == 0){
				if(contador2 == 1){
					// Encender 1000
					HAL_GPIO_WritePin(L21_GPIO_Port, L21_Pin, 1);
					HAL_GPIO_WritePin(L22_GPIO_Port, L22_Pin, 0);
					HAL_GPIO_WritePin(L23_GPIO_Port, L23_Pin, 0);
					HAL_GPIO_WritePin(L24_GPIO_Port, L24_Pin, 0);
				}else if(contador2 == 2){
					// Encender 0100
					HAL_GPIO_WritePin(L21_GPIO_Port, L21_Pin, 0);
					HAL_GPIO_WritePin(L22_GPIO_Port, L22_Pin, 1);
					HAL_GPIO_WritePin(L23_GPIO_Port, L23_Pin, 0);
					HAL_GPIO_WritePin(L24_GPIO_Port, L24_Pin, 0);
				}else if(contador2 == 3){
					// Encender 0010
					HAL_GPIO_WritePin(L21_GPIO_Port, L21_Pin, 0);
					HAL_GPIO_WritePin(L22_GPIO_Port, L22_Pin, 0);
					HAL_GPIO_WritePin(L23_GPIO_Port, L23_Pin, 1);
					HAL_GPIO_WritePin(L24_GPIO_Port, L24_Pin, 0);
				}
			}else if (contador2 == 4){
				// Se termina juego
				finish = 1;
				// Apagamos todas las leds jugador 1
				HAL_GPIO_WritePin(L11_GPIO_Port, L11_Pin, 0);
				HAL_GPIO_WritePin(L12_GPIO_Port, L12_Pin, 0);
				HAL_GPIO_WritePin(L13_GPIO_Port, L13_Pin, 0);
				HAL_GPIO_WritePin(L14_GPIO_Port, L14_Pin, 0);
				// Encendemos todas las leds jugador 2
				HAL_GPIO_WritePin(L21_GPIO_Port, L21_Pin, 1);
				HAL_GPIO_WritePin(L22_GPIO_Port, L22_Pin, 1);
				HAL_GPIO_WritePin(L23_GPIO_Port, L23_Pin, 1);
				HAL_GPIO_WritePin(L24_GPIO_Port, L24_Pin, 1);
				// Mostramos 2 en display
				HAL_GPIO_WritePin(D0_GPIO_Port, D0_Pin, 1);
				HAL_GPIO_WritePin(D1_GPIO_Port, D1_Pin, 0);
				HAL_GPIO_WritePin(D2_GPIO_Port, D2_Pin, 1);
				HAL_GPIO_WritePin(D3_GPIO_Port, D3_Pin, 1);
				HAL_GPIO_WritePin(D4_GPIO_Port, D4_Pin, 1);
				HAL_GPIO_WritePin(D5_GPIO_Port, D5_Pin, 1);
				HAL_GPIO_WritePin(D6_GPIO_Port, D6_Pin, 0);
			}
		}
}
/* USER CODE END 4 */

