  MX_GPIO_Init();
  MX_DMA_Init();
  MX_USART2_UART_Init();
  MX_TIM2_Init();
  MX_DAC_Init();
  MX_TIM6_Init();
  /* USER CODE BEGIN 2 */
  HAL_UART_Receive_IT(&huart2, &rxData, 1);
  mostrarMenu();
  HAL_TIM_PWM_Start(&htim2, TIM_CHANNEL_2);
  generarSin();
  /* USER CODE END 2 */

  /* Infinite loop */
  /* USER CODE BEGIN WHILE */
  while (1)
  {
	  if(rxData == '1')
	  	  {
	  		  rxData = 0;
	  		  sprintf(msg, "Seleccionaste PWM\r\nCaminando hacia Mordor...\r\n");
	  		  HAL_UART_Transmit(&huart2, (uint8_t*)msg, strlen(msg), HAL_MAX_DELAY);

	  		  int num_notas = sizeof(fellowship_theme) / sizeof(fellowship_theme[0]);
	  		  //int num_notas = sizeof(pirates_theme) / sizeof(pirates_theme[0]);
	  		  for (int i = 0; i < num_notas; i++) {
	  		      tocarNota(fellowship_theme[i].frecuencia, fellowship_theme[i].duracion);
	  			  //tocarNota(pirates_theme[i].frecuencia, pirates_theme[i].duracion);
	  		  }

	  		  // LIMPIEZA CRÍTICA:
	  		  rxData = 0; // Forzamos a cero por si presionaste algo mientras sonaba
	  		  mostrarMenu();
	  		  HAL_UART_Receive_IT(&huart2, &rxData, 1); // Reactivamos interrupción
	  	  }
	  	  else if(rxData == '2')
	  	  {
	  		  rxData = 0;
	  	      sprintf(msg, "Seleccionaste DAC\r\n");
	  	      HAL_UART_Transmit(&huart2, (uint8_t*)msg, strlen(msg), HAL_MAX_DELAY);

	  	      reproducirDAC();

	  	      mostrarMenu();
	  	      HAL_UART_Receive_IT(&huart2, &rxData, 1);
	  	  }
    /* USER CODE END WHILE */

    /* USER CODE BEGIN 3 */
  }
  /* USER CODE END 3 */
}

