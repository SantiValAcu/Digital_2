void tocarNota(uint32_t frecuencia, uint32_t duracion_ms)
{
    if (frecuencia == 0) {
        __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_2, 0);
    } else {
        uint32_t timer_clk = 84000000;
        uint32_t prescaler = (timer_clk / (frecuencia * 256)) - 1;

        __HAL_TIM_SET_PRESCALER(&htim2, prescaler);
        __HAL_TIM_SET_COUNTER(&htim2, 0);
        __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_2, 128); // 50%
    }

    HAL_Delay(duracion_ms);

    __HAL_TIM_SET_COMPARE(&htim2, TIM_CHANNEL_2, 0);
    HAL_Delay(20);
}
void reproducirDAC(void)
{
    int sizeM = sizeof(zelda_notes)/sizeof(zelda_notes[0]);

    HAL_DAC_Start(&hdac, DAC_CHANNEL_1);

    for(int i = 0; i < sizeM; i++)
    {
        HAL_TIM_Base_Stop_IT(&htim6);
        sine_idx = 0;

        if(zelda_notes[i] != 0)
        {
            __HAL_TIM_SET_AUTORELOAD(&htim6, zelda_notes[i]);
            __HAL_TIM_SET_COUNTER(&htim6, 0);

            HAL_TIM_Base_Start_IT(&htim6);
        }
        else
        {
            HAL_DAC_SetValue(&hdac, DAC_CHANNEL_1, DAC_ALIGN_8B_R, 128);
        }

        HAL_Delay(zelda_duration[i]);
    }

    HAL_TIM_Base_Stop_IT(&htim6);
    HAL_DAC_Stop(&hdac, DAC_CHANNEL_1);
}
void generarSin()
{
    for (int x = 0; x < size; x++){
        Ysine[x] = (uint8_t)((sin(2 * M_PI * x / size) * 127) + 128);
    }
}
void HAL_TIM_PeriodElapsedCallback(TIM_HandleTypeDef *htim)
{
    if (htim->Instance == TIM6)
    {
        HAL_DAC_SetValue(&hdac, DAC_CHANNEL_1, DAC_ALIGN_8B_R, Ysine[sine_idx]);

        sine_idx++;
        if (sine_idx >= size) {
            sine_idx = 0;
        }
    }
}
